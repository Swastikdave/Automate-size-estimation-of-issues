name: Auto Assign Story Points

on:
  issues:
    types: [opened, labeled]
  project_v2_item:
    types: [created, edited]

jobs:
  assign-points:
    runs-on: ubuntu-latest

    permissions:
      contents: read
      issues: write
      repository-projects: write

    steps:
      - name: Assign points
        uses: actions/github-script@v7
        with:
          script: |
            const projectId = "PUT_LATER";   // we’ll skip for now
            const fieldName = "Estimate";

            let issueNodeId;

            if (context.eventName === "issues") {
              issueNodeId = context.payload.issue.node_id;
            } else {
              issueNodeId = context.payload.project_v2_item.content_node_id;
            }

            // get labels
            const issue = await github.graphql(`
              query {
                node(id: "${issueNodeId}") {
                  ... on Issue {
                    labels(first: 10) {
                      nodes { name }
                    }
                    projectItems(first: 10) {
                      nodes {
                        id
                        project { id }
                      }
                    }
                  }
                }
              }
            `);

            const labels = issue.node.labels.nodes.map(l => l.name);

            let points = 0;
            if (labels.includes("XS")) points = 1;
            else if (labels.includes("S")) points = 2;
            else if (labels.includes("M")) points = 3;
            else if (labels.includes("L")) points = 5;
            else if (labels.includes("XL")) points = 8;

            if (points === 0) return;

            const item = issue.node.projectItems.nodes[0];

            if (!item) {
              console.log("Not in project yet");
              return;
            }

            // Now update field (we'll plug field ID next)
            console.log("Points computed:", points);
